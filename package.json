{
  "name": "cc-box",
  "version": "0.12.8",
  "description": "Claude Code Desktop GUI (Tauri) - Multi-terminal manager for Claude Code power users",
  "license": "MIT",
  "author": {
    "name": "orczh",
    "email": "orczh_hj@163.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/orczh-hj/cc-box.git"
  },
  "bugs": {
    "url": "https://github.com/orczh-hj/cc-box/issues"
  },
  "homepage": "https://github.com/orczh-hj/cc-box#readme",
  "keywords": [
    "claude-code",
    "claude",
    "tauri",
    "terminal",
    "gui",
    "multi-session",
    "developer-tools"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build:win": "tauri build --target x86_64-pc-windows-gnu",
    "build:mac": "tauri build --target x86_64-apple-darwin",
    "build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "release": "node scripts/release.js",
    "release:oss": "node scripts/release.js --oss-only",
    "download-deps": "node scripts/download-deps.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.6",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.42.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-global-shortcut": "^2.3.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "lodash-es": "^4.18.1",
    "macos-traffic-lights": "^1.0.1",
    "pinia": "^2.1.7",
    "v3-infinite-loading": "^1.3.2",
    "vue": "^3.4.0",
    "vue-codemirror": "^6.1.1",
    "vue-draggable-plus": "^0.6.1",
    "vue-i18n": "^9.14.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/lodash-es": "^4.17.12",
    "@vitejs/plugin-vue": "^5.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.0.0"
  }
