{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC-Box",
  "version": "0.4.1",
  "identifier": "com.cc-box.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CC-Box",
        "width": 800,
        "height": 600,
        "minWidth": 500,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "orczh",
    "copyright": "Copyright © 2025",
    "category": "Developer Tool",
    "shortDescription": "CC-Box — Multi-terminal manager for Claude Code",
    "longDescription": "A multi-terminal manager for Claude Code power users. Run multiple sessions in one window with sidebar panels, project quick launch, and native terminal experience.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": "-",
      "hardenedRuntime": false,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}