{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC Desk",
  "version": "0.14.0",
  "identifier": "io.github.shawnwu2022.ccdesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CC Desk",
        "width": 800,
        "height": 600,
        "minWidth": 500,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "shawnwu2022",
    "copyright": "Copyright © 2025 orczh; © 2026 CC Desk contributors",
    "category": "Developer Tool",
    "shortDescription": "CC Desk — Multi-project desktop workspace for Claude Code",
    "longDescription": "A multi-project, multi-session desktop workspace for Claude Code power users, with native terminal sessions, project navigation, status monitoring, and workflow tools.",
    "createUpdaterArtifacts": true,
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": "",
      "signingIdentity": "-",
      "hardenedRuntime": false,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerHooks": "./installer.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5OTA0ODkwNzQwNjVCMDYKUldRR1d3WjBrRWlRU2IrQVIxbnF2c0h2Z0tEUmd4aUl4UkhzZ2R0Lzdwc1FMVERMY3NqNzIrc3gK",
      "endpoints": [
        "https://github.com/shawnwu2022/cc-desk/releases/latest/download/latest.json"
      ]
    }
  }
}
